{
  "tech_stack": [
    "TypeScript",
    "Next.js",
    "React",
    "Tailwind CSS",
    "Supabase",
    "Google Gemini API",
    "Upstash Redis"
  ],
  "features": [
    {
      "name": "Schedule System",
      "description": "View and manage class schedules, including editing for admins/leaders and notifications.",
      "files": [
        "src/app/schedule/page.tsx",
        "src/app/schedule/[section]/page.tsx",
        "src/app/schedule/[section]/edit/page.tsx",
        "src/app/schedule/actions.ts",
        "src/components/schedule/ScheduleNotificationToggle.tsx",
        "src/components/schedule/UpcomingClassCard.tsx"
      ]
    },
    {
      "name": "Authentication",
      "description": "User login and session management via Supabase Auth.",
      "files": [
        "src/app/login/page.tsx",
        "src/app/login/actions.ts",
        "src/middleware.ts",
        "src/components/auth/AuthButton.tsx"
      ]
    },
    {
      "name": "Admin Dashboard",
      "description": "Dashboard for administrators to manage the application.",
      "files": [
        "src/app/admin/page.tsx",
        "src/app/admin/layout.tsx",
        "src/components/admin/AdminSidebar.tsx"
      ]
    },
    {
      "name": "Gamification",
      "description": "XP system, levels, and leaderboards to engage students.",
      "files": [
        "src/components/gamification/XPNotification.tsx",
        "src/lib/gamification.ts",
        "src/app/leaderboard/page.tsx"
      ]
    },
    {
      "name": "Guild System",
      "description": "Team-based grouping for students with shared activities.",
      "files": [
        "src/app/guild/page.tsx",
        "src/components/guild/GuildCard.tsx",
        "src/components/guild/CreateGuildModal.tsx"
      ]
    },
    {
      "name": "Course Content",
      "description": "Displaying lessons, chapters, and quizzes.",
      "files": [
        "src/app/courses/[subject]/page.tsx",
        "src/app/courses/[subject]/[chapter]/page.tsx",
        "src/components/courses/LessonCard.tsx"
      ]
    },
    {
      "name": "AI Companion",
      "description": "Chatbot interface for student assistance.",
      "files": [
        "src/components/ai/ChatInterface.tsx",
        "src/app/api/chat/route.ts"
      ]
    },
    {
      "name": "Onboarding",
      "description": "User onboarding process for new accounts.",
      "files": [
        "src/app/onboarding/page.tsx",
        "src/app/onboarding/start/page.tsx"
      ]
    }
  ]
}